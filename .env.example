# Gemini translation fallback for oracle text
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Number of built-in KEYWORD_THAI_MAP entries to include in prompt
GEMINI_GLOSSARY_LIMIT=80
# Optional additional glossary lines (format: "source => target", one per line)
# GEMINI_GLOSSARY_EXTRA=flying => บินได้\nward => ป้องกัน
